---
import Header from "../modular/Header.astro";
import Navigation from "../modular/Navigation.astro";

import { Image } from 'astro:assets';

import { isPage, isSubPage } from '../../../scripts/page';

const { pathname } = Astro.url;
const curPage = pathname.slice(1);
const curPageS = curPage === '' ? ' / ' : curPage.replace(/\//g, " / ")
---
<Header>
    <!-- slot nav-left -->
    <Image slot="nav-left" loading="eager" src="/favicon.ico" alt="cat icon" width="32" height="32" class="rounded-full" />
    <h2 slot="nav-left">trevi's website</h2>
    <!-- slot nav-center -->
    <p slot="nav-center" class="italic text-white/70">{curPageS}</p>
    <!-- slot nav-right -->
    <Navigation slot="nav-right">
        <a href="/"            aria-current={isPage   (curPage, '')                          }>home</a>
        <a href="/megathread/" aria-current={isSubPage(curPage, 'megathread/')               }>megathread</a>
        <a href="/blog/"       aria-current={isSubPage(curPage, ['blog/', 'tags/', 'posts/'])}>blog</a>
    </Navigation>
</Header>
