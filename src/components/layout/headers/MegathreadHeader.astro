---
import Header from "../modular/Header.astro";
import Navigation from "../modular/Navigation.astro";

const { pathname } = Astro.url;
const curPage = pathname.slice(1);

import { isPage } from '../../../scripts/page';
---
<Header color="dim" stripe="stripedim">
    <!-- slot nav-left -->
    <p slot="nav-left">MEGATHREAD</p>
    <!-- slot nav-center -->

    <!-- slot nav-right -->
    <Navigation slot="nav-right">
        <a href="/megathread/"          aria-current={isPage(curPage, 'megathread/')         }>main</a>
        <a href="/megathread/tinysoft/" aria-current={isPage(curPage, 'megathread/tinysoft/')}>software</a>
    </Navigation>
</Header>
