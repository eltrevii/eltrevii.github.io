---
import Header from "../modular/Header.astro";
import Navigation from "../modular/Navigation.astro";

const { pathname } = Astro.url;
const curPage = pathname.slice(1);

import { isSubPage } from '../../../scripts/page';
---
<Header color="dim" stripe="stripedim">
    <!-- slot nav-left -->
    <p slot="nav-left">BLOG</p>
    <!-- slot nav-center -->

    <!-- slot nav-right -->
    <Navigation slot="nav-right">
        <a href="/blog/" aria-current={isSubPage(curPage, 'blog/')}>all posts</a>
        <a href="/tags/" aria-current={isSubPage(curPage, 'tags/')}>tags</a>
    </Navigation>
</Header>
